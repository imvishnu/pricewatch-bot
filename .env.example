# Copy to .env and fill in. Load with: set -a; source .env; set +a
DATABASE_URL=postgresql://pricewatch:changeme@localhost:5432/pricewatch
TELEGRAM_BOT_TOKEN=123456:ABC-your-botfather-token

# Price source: "scraper" (default, no credentials needed) or "creators"
PRICE_SOURCE=scraper

# Only required when PRICE_SOURCE=creators:
CREATORS_CLIENT_ID=
CREATORS_CLIENT_SECRET=
PARTNER_TAG=

# Only required for the channel watcher (pricewatch.channelwatch):
# api credentials from https://my.telegram.org (personal account)
TG_API_ID=
TG_API_HASH=
TG_SESSION=/opt/pricewatch-bot/channelwatch.session
# comma-separated deals channels to watch (@username, link or channel id);
# public channels are joined automatically
WATCH_CHANNELS=@offersignal,@SmartDealsOfindia,@techy_mohit
